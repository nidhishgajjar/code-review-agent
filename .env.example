# ─── Free LLM Providers (pick one or more) ───

# Google AI Studio (RECOMMENDED — best free limits, 1M context)
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenRouter (29 free models including Qwen3 Coder)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq (fast inference, 1K req/day)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=

# Cerebras (fastest inference)
# Get key at: https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# DeepSeek (10M free tokens on signup)
# Get key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Mistral (requires phone verification)
# Get key at: https://console.mistral.ai
MISTRAL_API_KEY=

# ─── GitHub ───
# Required for posting reviews & accessing private repos
GITHUB_TOKEN=ghp_...

# ─── Model Selection ───
# Override the default model (LiteLLM format)
# LLM_MODEL=gemini/gemini-2.5-flash
# LLM_MODEL=openrouter/qwen/qwen3-coder:free
# LLM_MODEL=groq/llama-3.3-70b-versatile

# ─── Target Repo (can also pass via --repo CLI flag) ───
# REVIEW_REPO_URL=https://github.com/owner/repo
